# --------------------------------------------------------------------------
# Keygen portal is configured through environment variables. Uncommented
# environment variables are mandatory. Failure to provide all mandatory
# environment variables will result in pain.
#
# For more information, visit: https://keygen.sh/docs/self-hosting/
# --------------------------------------------------------------------------

# The host that the Keygen API is accessible at, e.g. api.keygen.sh.
VITE_KEYGEN_HOST=api.keygen.localhost

# The API version that the portal targets.
VITE_KEYGEN_VERSION=1.8

# The account ID used for setting the tenant of the portal.
VITE_KEYGEN_ACCOUNT_ID=

# The edition of Keygen to target.
# Either CE for Community Edition, or EE for Enterprise Edition.
VITE_KEYGEN_EDITION=CE

# The mode of Keygen.
# Either singleplayer for single-tenant, or multiplayer for multi-tenant.
VITE_KEYGEN_MODE=singleplayer

# Additional hosts that the Vite dev server will accept,
# e.g. portal.keygen.dev, localhost, etc.
# VITE_ALLOWED_HOSTS=

# DSN for BetterStack error reporting via the Sentry SDK,
# e.g. https://$APPLICATION_TOKEN@$INGESTING_HOST/$APPLICATION_ID
# VITE_SENTRY_DSN=

# Environment label used on each BetterStack error report, e.g. development or production.
# Defaults to "production" if not set, which is Sentry's default environment label.
# VITE_SENTRY_ENVIRONMENT=
